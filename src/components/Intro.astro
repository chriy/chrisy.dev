<section class=" max-w-10/12 mx-auto grid grid-cols-3 justify-center items-center gap-x-2 md:gap-x-6 max-xl:grid-cols-2 max-md:grid-cols-1">
    <div class=" p-8 @container relative overflow-auto rounded-lg bg-white h-40 outline outline-white/5 dark:bg-gray-950/50 dark:inset-ring dark:inset-ring-white/5 group-data-dragging:before:absolute group-data-dragging:before:inset-0">
    </div>
    <div class=" p-8 @container relative overflow-auto rounded-lg bg-white h-40  outline outline-white/5 dark:bg-gray-950/50 dark:inset-ring dark:inset-ring-white/5 group-data-dragging:before:absolute group-data-dragging:before:inset-0">

    </div>
    <div class=" p-8 @container relative overflow-auto rounded-lg bg-white w-fit h-40 outline outline-white/5 dark:bg-gray-950/50 dark:inset-ring dark:inset-ring-white/5 group-data-dragging:before:absolute group-data-dragging:before:inset-0">

    </div>
    <!--<div class="col-span-1 max-md:col-span-3 gap-x-5 gap-y-5 flex items-start justify-center flex-col bg-primary-blue">1</div>-->
    <!--<div class="col-span-1 max-md:col-span-3 gap-x-5 gap-y-5 flex items-start justify-center flex-col bg-primary-blue">Da Vinci Code by Dan Brown</div>-->
    <!--<div class="col-span-1 max-md:col-span-3 gap-x-5 gap-y-5 flex items-start justify-center flex-col bg-primary-blue">3</div>-->
</section>
<section class="relative w-full h-screen overflow-hidden bg-white dark:bg-neutral-950">
    <!-- 斜线背景 -->
    <div class="absolute inset-0 bg-[linear-gradient(120deg,rgba(255,255,255,0.05)_1px,transparent_1px)]
              bg-[size:40px_40px] dark:bg-[linear-gradient(120deg,rgba(255,255,255,0.08)_1px,transparent_1px)]">
    </div>

    <!-- 流星容器 -->
    <div class="absolute inset-0 pointer-events-none">
        <span class="meteor"></span>
        <span class="meteor"></span>
        <span class="meteor"></span>
        <span class="meteor"></span>
        <span class="meteor"></span>
    </div>

    <!-- 文字内容 -->
    <div class="relative z-10 flex flex-col items-center justify-center h-full text-center">
        <h1 class="text-4xl md:text-6xl font-bold text-white">
            Idea to website in <br><span class="text-gray-400">minutes, not hours.</span>
        </h1>
        <p class="mt-4 text-gray-400">Get the best beam tracking services...</p>
        <div class="mt-6 flex gap-4">
            <button class="px-6 py-2 rounded-lg bg-white text-black font-semibold">Buy now</button>
            <button class="px-6 py-2 rounded-lg bg-neutral-800 text-white">Explore beams</button>
        </div>
    </div>

    <style>
        @keyframes meteor {
            0% {
                transform: translateX(0) translateY(0) rotate(45deg);
                opacity: 1;
            }
            70% {
                opacity: 1;
            }
            100% {
                transform: translateX(-300px) translateY(300px) rotate(45deg);
                opacity: 0;
            }
        }
        .meteor {
            position: absolute;
            top: -50px;
            left: 80%;
            width: 2px;
            height: 100px;
            background: linear-gradient(180deg, yellow, transparent);
            opacity: 0;
            animation: meteor 2s linear infinite;
        }
        .meteor:nth-child(2) { left: 20%; animation-delay: 1s; }
        .meteor:nth-child(3) { left: 40%; animation-delay: 2s; }
        .meteor:nth-child(4) { left: 60%; animation-delay: 3s; }
        .meteor:nth-child(5) { left: 75%; animation-delay: 4s; }
    </style>
</section>
<section class="relative w-full h-screen overflow-hidden bg-black dark:bg-neutral-950">
    <!-- 背景斜线 -->
    <div class="absolute inset-0
              bg-[linear-gradient(-120deg,rgba(255,255,255,0.05)_1px,transparent_1px)]
              bg-[size:40px_40px]
              dark:bg-[linear-gradient(-120deg,rgba(255,255,255,0.08)_1px,transparent_1px)]">
    </div>

    <!-- 流星容器 -->
    <div class="absolute inset-0 pointer-events-none">
        <span class="meteor"></span>
        <span class="meteor"></span>
        <span class="meteor"></span>
        <span class="meteor"></span>
        <span class="meteor"></span>
    </div>

    <!-- 文字内容 -->
    <div class="relative z-10 flex flex-col items-center justify-center h-full text-center">
        <h1 class="text-4xl md:text-6xl font-bold text-white">
            Idea to website in <br><span class="text-gray-400">minutes, not hours.</span>
        </h1>
        <p class="mt-4 text-gray-400">
            Get the best beam tracking services in the world with our state of the art,
            cutting edge beam detection technology.
        </p>
        <div class="mt-6 flex gap-4">
            <button class="px-6 py-2 rounded-lg bg-white text-black font-semibold">Buy now</button>
            <button class="px-6 py-2 rounded-lg bg-neutral-800 text-white">Explore beams</button>
        </div>
    </div>

    <style>
        @keyframes meteor {
            0% {
                transform: translateX(0) translateY(0) rotate(-45deg);
                opacity: 1;
            }
            70% {
                opacity: 1;
            }
            100% {
                transform: translateX(300px) translateY(300px) rotate(-45deg);
                opacity: 0;
            }
        }

        .meteor {
            position: absolute;
            top: -100px;
            left: 20%;
            width: 2px;
            height: 120px;
            background: linear-gradient(180deg, #facc15, transparent); /* 黄到透明 */
            opacity: 0;
            animation: meteor 2.5s linear infinite;
        }

        /* 随机不同位置和延迟 */
        .meteor:nth-child(1) { left: 10%; animation-delay: 0s; animation-duration: 2s; }
        .meteor:nth-child(2) { left: 35%; animation-delay: 1s; animation-duration: 2.8s; }
        .meteor:nth-child(3) { left: 55%; animation-delay: 2s; animation-duration: 2.3s; }
        .meteor:nth-child(4) { left: 70%; animation-delay: 3s; animation-duration: 2.6s; }
        .meteor:nth-child(5) { left: 85%; animation-delay: 4s; animation-duration: 3s; }
    </style>
</section>
