{
  "name": "Dev Container",
  "dockerFile": "Dockerfile",
  "context": "..",
  "appPort": [
    3000
  ],
  "postCreateCommand": "npm install",
  "customizations": {
    "vscode": {
      "extensions": [
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint",
        "bradlc.vscode-tailwindcss"
      ]
    }
  },
  "remoteUser": "root"
}
